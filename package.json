{
  "name": "shopfleet",
  "version": "0.1.9",
  "description": "Multi-store Shopify CLI",
  "type": "module",
  "bin": {
    "shopfleet": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shopify",
    "cli",
    "graphql"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
